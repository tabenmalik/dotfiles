#!/usr/bin/env python3
from __future__ import annotations

import argparse
import subprocess
from collections.abc import Sequence
from typing import NamedTuple


class Branch(NamedTuple):
    name: str
    remote_tracking: str


def main(argv: Sequence[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="git gone",
        description="Remove local branches that have unknown upstream refs.",
    )
    parser.add_argument("-n", "--dry-run", action="store_true")
    args = parser.parse_args(argv)

    for_each_cmd = (
        "git", "for-each-ref",
        "--format=%(refname:short):%(upstream:track,nobracket)",
        "--", "refs/heads",
    )
    for_each_output = subprocess.run(
        for_each_cmd, capture_output=True, text=True, check=True,
    )

    branches = [
        Branch(*line.split(":"))
        for line in for_each_output.stdout.strip().splitlines()
    ]

    del_cmd = ("git", "branch", "--delete", "--force")
    for branch in branches:
        if branch.remote_tracking == "gone":
            if args.dry_run:
                print(f"Would delete branch {branch.name}")
            else:
                _ = subprocess.run((*del_cmd, branch.name))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
