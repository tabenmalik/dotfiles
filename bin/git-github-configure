#!/usr/bin/env python3
# inspired by asottile's git subcommands:
#    github.com/asottile/scratch/tree/main/python
from __future__ import annotations

import argparse
import json
import os
import subprocess
import tempfile
import urllib.parse
import urllib.request
from collections.abc import Sequence

SSH_GH = 'git@github.com:'

API_BASE = 'https://api.github.com'


def _get_github_project(remote: str) -> str:
    cmd = ('git', 'config', f'remote.{remote}.url')
    remote_url = subprocess.check_output(cmd).strip().decode()
    if not remote_url.startswith(SSH_GH):
        raise SystemExit(
            f'remote is not a GitHub project, '
            f"got 'remote.{remote}.url={remote_url}'",
        )

    project = remote_url[len(SSH_GH):]
    project = project.rstrip('.git')
    return project


def _get_creds() -> str:
    token = os.environ.get('GITHUB_TOKEN', "")
    if token:
        return token

    file = os.path.expanduser('~/.github-auth.json')
    mode = os.stat(file).st_mode & 0o777
    if mode != 0o600:
        raise SystemExit(
            f'{file} has too permissive permissions, expected 0o600, '
            f'got 0o{mode:o}',
        )

    with open(file) as f:
        github_auth = json.load(f)
        return github_auth["token"]


def _check_for_wiki(project: str, force: bool) -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        wiki_repo = f'{SSH_GH}{project}.wiki'
        cmd = ('git', 'clone', '--depth=1', wiki_repo, temp_dir)
        cp = subprocess.run(cmd, capture_output=True)
        if not cp.returncode and not force:
            raise SystemExit(
                f"Project has wiki contents at '{wiki_repo}'. "
                'Use -f/--force to disable the wiki.',
            )


def main(argv: Sequence[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description=(
            'Configure github settings of remote. '
            'Requires GitHub token searched in GITHUB_TOKEN envvar '
            'then in ~/.github-auth.json.'
        ),
    )

    parser.add_argument('-f', '--force', action='store_true')

    parser.add_argument(
        'remote',
        help=(
            'The remote to configure. '
            'Must be a GitHub SSH remote.'
        ),
    )

    args = parser.parse_args(argv)

    project = _get_github_project(args.remote)
    _check_for_wiki(project, args.force)

    token = _get_creds()
    update_fields = {
        'delete_branch_on_merge': True,
        'has_wiki': False,
        'has_projects': False,
    }
    url = f'{API_BASE}/repos/{project}'
    request_data = json.dumps(update_fields).encode()
    request = urllib.request.Request(url, method='PATCH', data=request_data)
    request.add_header('Authorization', f'token {token}')
    urllib.request.urlopen(request)
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
